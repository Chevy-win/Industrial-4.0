            //CUALLOY Batch Run
            List<string> cualloyLot = new List<string>();
            int cualloyBatchSize = 0;
            int cualloyMinWaferCountPerBatch = 0;
            foreach (DataRow dr in dt_input.Rows)
            {
                if (dr["EqpType"].ToString() == "CUALLOY" && !cualloyLot.Contains(dr["LotID"].ToString()))
                {
                    cualloyLot.Add(dr["LotID"].ToString());
                    cualloyBatchSize = Convert.ToInt32(dr["BatchSize"]);
                    cualloyMinWaferCountPerBatch = Convert.ToInt32(dr["MinWaferCountPerBatch"]);
                }
            }
            foreach (DataRow dr in dt_input.Rows)
            {
                if (cualloyLot.Contains(dr["LotID"].ToString()) && Convert.ToInt32(dr["BatchSize"]) > cualloyBatchSize && Convert.ToInt32(dr["BatchSize"]) < 99 && dr["RTDEqpType"].ToString() == "Furnace")
                    dr["BatchSize"] = cualloyBatchSize;
                if (cualloyLot.Contains(dr["LotID"].ToString()) && Convert.ToInt32(dr["MinWaferCountPerBatch"]) > cualloyMinWaferCountPerBatch && dr["RTDEqpType"].ToString() == "Furnace")
                    dr["MinWaferCountPerBatch"] = cualloyMinWaferCountPerBatch;
            }

            //Eqp Info
            using (StreamReader reader = new StreamReader(INPUTFILE_Eqp))
            {
                reader.ReadLine();
                while (!reader.EndOfStream)
                {
                    string row = reader.ReadLine();
                    string[] values = row.Split(',');
                    dt_input_eqp.Rows.Add(values[0], values[1], values[3], "", (values[6] == "Y" ? true : false),
                        DateTime.TryParseExact(values[7], "yyyyMMdd HHmmss", CultureInfo.InvariantCulture, DateTimeStyles.None, out datetimeTemp) ? datetimeTemp : currentTime, 0,
                        int.TryParse(values[13], out intTemp) ? intTemp : 0,
                        DateTime.TryParseExact(values[14], "yyyyMMdd HHmmss", CultureInfo.InvariantCulture, DateTimeStyles.None, out datetimeTemp) ? datetimeTemp : currentTime, 0,
                        (values[16] == "1" ? 1 : 0));
                }
            }

            foreach (DataRow dr in dt_input_eqp.Rows)
            {
                if (dr["EqpType"].ToString() == "CUSTRIP" || dr["EqpType"].ToString() == "CUSOVT" || dr["EqpType"].ToString() == "CUNITINCVD" || dr["EqpType"].ToString() == "CUOXE"
                    || dr["EqpType"].ToString() == "CUSINE" || dr["EqpType"].ToString() == "CUMETE" || dr["EqpType"].ToString() == "CUPLATE" || dr["EqpType"].ToString() == "CUSPUT")
                {
                    dr["ChamberType"] = "Chamber";
                }
                else
                {
                    dr["ChamberType"] = "Eqp";
                }
                availTime = Math.Truncate(Convert.ToDateTime(dr["AvailTime"]).Subtract(currentTime).TotalMinutes);
                availTime = availTime < 0 ? 0 : availTime;
                dr["AvailTimeInMinute"] = availTime;
                if (dr["EqpType"].ToString() == "CUSTRIP" || dr["EqpType"].ToString() == "CUSOVT" || dr["EqpType"].ToString() == "CUNITINCVD" || dr["EqpType"].ToString() == "CUOXE"
                    || dr["EqpType"].ToString() == "CUSINE" || dr["EqpType"].ToString() == "CUMETE" || dr["EqpType"].ToString() == "CUPLATE" || dr["EqpType"].ToString() == "CUSPUT")
                {
                    if (Convert.ToBoolean(dr["ToolDown"]))
                        dr["AvailTimeInMinute"] = DUEDATE;
                }

                // Get CUSOVT next change chemical remain minute
                if (dr["EqpType"].ToString() == "CUSOVT")
                {
                    CUSOVTNextCCStopTime = Math.Truncate(Convert.ToDateTime(dr["CUSOVTNextCCStopTime"]).Subtract(currentTime).TotalMinutes);
                    //CUSOVTChemicalLifetime = double.TryParse(dr["CUSOVTChemicalLifetime"].ToString(), out doubleTemp) ? doubleTemp : 99999999;
                    //CUSOVTNextCCStopInMinute = (CUSOVTChemicalLifetime - CUSOVTNextCCStopTime) < 0 ? 0 : (CUSOVTChemicalLifetime - CUSOVTNextCCStopTime);
                    dr["CUSOVTNextCCStopInMinute"] = CUSOVTNextCCStopTime;
                }
            }

            List<string> chamberUsed = new List<string>();
            foreach (DataRow dr in dt_input.Rows)
            {
                if (dr["EqpType"].ToString() == "CUSTRIP" || dr["EqpType"].ToString() == "CUSOVT" || dr["EqpType"].ToString() == "CUNITINCVD" || dr["EqpType"].ToString() == "CUOXE"
                    || dr["EqpType"].ToString() == "CUSINE" || dr["EqpType"].ToString() == "CUMETE" || dr["EqpType"].ToString() == "CUPLATE" || dr["EqpType"].ToString() == "CUSPUT")
                {
                    string[] chamberRequired = dr["ChamberRequired"].ToString().Split(':');
                    foreach (string c in chamberRequired)
                        if (!chamberUsed.Contains(c))
                            chamberUsed.Add(c);
                }
            }

            for (int i = dt_input_eqp.Rows.Count - 1; i >= 0; i--)
                if (!chamberUsed.Contains(dt_input_eqp.Rows[i]["ChamberID"].ToString()))
                    dt_input_eqp.Rows[i].Delete();
            dt_input_eqp.AcceptChanges();
        }

