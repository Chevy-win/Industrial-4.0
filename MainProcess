        static bool CheckInputFileExist()
        {
            bool inputFileLotExist = false;
            bool inputFileEqpExist = false;
            DateTime tempDate = DateTime.MinValue;
            string fileTime = "";
            string[] allFiles = Directory.GetFiles(Directory.GetCurrentDirectory());
            // Get Input_Lot File 
            foreach (string aFile in allFiles)
            {
                string FileName = Path.GetFileName(aFile);
                if (FileName.StartsWith("Input_Lot_") && Path.GetExtension(FileName) == ".csv" && FileName.Length == 28)
                {

                    string fileDate = FileName.Substring(10, 14);
                    if (DateTime.TryParseExact(fileDate, "yyyyMMddHHmmss", CultureInfo.InvariantCulture, DateTimeStyles.None, out tempDate))
                    {
                        if (DateTime.Compare(tempDate, currentTime) > 0)
                        {
                            inputFileLotExist = true;
                            currentTime = tempDate;
                            fileTime = fileDate;
                            INPUTFILE_Lot = FileName;
                        }
                    }
                }
            }
            if (inputFileLotExist)
            {
                foreach (string aFile in allFiles)
                {
                    string FileName = Path.GetFileName(aFile);
                    if (FileName == "Input_Eqp_" + fileTime + ".csv")
                    {
                        inputFileEqpExist = true;
                        INPUTFILE_Eqp = FileName;
                    }
                }
                //Console.WriteLine("file exist.");
                //System.Diagnostics.Debug.WriteLine("file exist.");
            }
            return inputFileLotExist && inputFileEqpExist;
        }

        static void CeilingCurrentTime()
        {
            currentTime = new DateTime((currentTime.Ticks + TimeSpan.FromMinutes(1).Ticks - 1) / TimeSpan.FromMinutes(1).Ticks * TimeSpan.FromMinutes(1).Ticks, currentTime.Kind);
        }

