                dr["AvailDispInMinute"] = availDisp;

                availTime = Math.Truncate(Convert.ToDateTime(dr["AvailTime"]).Subtract(currentTime).TotalMinutes);
                availTime = availTime < 0 ? 0 : availTime;
                dr["AvailTimeInMinute"] = availTime;

                if ((Convert.ToDateTime(dr["AdvInhibit"]) == DateTime.MaxValue))
                {
                    dr["AdvInhibitInMinute"] = DUEDATE;
                }
                else
                {
                    advInhibit = Math.Truncate(Convert.ToDateTime(dr["AdvInhibit"]).Subtract(currentTime).TotalMinutes);
