    dt_input_foup.Columns.Add("RQTEqpType1", typeof(string));
    dt_input_foup.Columns.Add("RQTSeq1", typeof(int));
    dt_input_foup.Columns.Add("RQT1", typeof(int));
    dt_input_foup.Columns.Add("RQTEqpType2", typeof(string));
    dt_input_foup.Columns.Add("RQTSeq2", typeof(int));
    dt_input_foup.Columns.Add("RQT2", typeof(int));
    dt_input_foup.Columns.Add("RQTEqpType3", typeof(string));
    dt_input_foup.Columns.Add("RQTSeq3", typeof(int));
    dt_input_foup.Columns.Add("RQT3", typeof(int));
    dt_input_foup.Columns.Add("QTimeEqpType1", typeof(string));
    dt_input_foup.Columns.Add("QTimeSeq1", typeof(int));
    dt_input_foup.Columns.Add("QTime1", typeof(int));
    dt_input_foup.Columns.Add("QTimeEqpType2", typeof(string));
    dt_input_foup.Columns.Add("QTimeSeq2", typeof(int));
    dt_input_foup.Columns.Add("QTime2", typeof(int));
    dt_input_foup.Columns.Add("QTimeEqpType3", typeof(string));
    dt_input_foup.Columns.Add("QTimeSeq3", typeof(int));
    dt_input_foup.Columns.Add("QTime3", typeof(int));
    dt_input_foup.Columns.Add("EqRecoveryStartTime", typeof(DateTime));
    dt_input_foup.Columns.Add("EqRecoveryStartTimeInMinute", typeof(int));
    dt_input_foup.Columns.Add("EqRecoveryEndTime", typeof(DateTime));
    dt_input_foup.Columns.Add("EqRecoveryEndTimeInMinute", typeof(int));
    dt_input_foup.Columns.Add("BatchSize", typeof(int));
    dt_input_foup.Columns.Add("MaxBatchSize", typeof(int));
    dt_input_foup.Columns.Add("MinWaferCountPerBatch", typeof(int));
    dt_input_foup.Columns.Add("MinBatchWafers", typeof(int));
    dt_input_foup.Columns.Add("MaxBatchWafers", typeof(int));
    //dt_input_foup.Columns.Add("AllowSingleFOUPRun", typeof(int));
    dt_input_foup.Columns.Add("IgnoreBatchSize", typeof(int));

    DataTable dt1 = new DataView(dt_input).ToTable(true, "FOUPID", "Seq", "EqpID", "Recipe", "PPID");
    foreach (DataRow dr1 in dt1.Rows)
    {
        DataTable dt2 = new DataTable();
        if (dt_input.Select(string.Format("FOUPID = '{0}' and Seq = {1} and EqpID = '{2}' and Recipe = '{3}' and PPID = '{4}'",
                dr1["FOUPID"].ToString(), Convert.ToInt32(dr1["Seq"]), dr1["EqpID"].ToString(), dr1["Recipe"].ToString(), dr1["PPID"].ToString())).Length > 0)
        {
            dt2 = dt_input.Select(string.Format("FOUPID = '{0}' and Seq = {1} and EqpID = '{2}' and Recipe = '{3}' and PPID = '{4}'",
                dr1["FOUPID"].ToString(), Convert.ToInt32(dr1["Seq"]), dr1["EqpID"].ToString(), dr1["Recipe"].ToString(), dr1["PPID"].ToString())).CopyToDataTable();
            int NumWafer = Convert.ToInt32(dt2.Compute("sum([NumWafer])", string.Empty));
            int IsActive = Convert.ToInt32(dt2.Compute("min([IsActive])", string.Empty));
            int AvailDispInMinute = Convert.ToInt32(dt2.Compute("max([AvailDispInMinute])", string.Empty));
            int AvailTimeInMinute = Convert.ToInt32(dt2.Compute("max([AvailTimeInMinute])", string.Empty));
            int AdvInhibitInMinute = Convert.ToInt32(dt2.Compute("min([AdvInhibitInMinute])", string.Empty));
            double Priority = Convert.ToInt32(dt2.Compute("min([Priority])", string.Empty));
            int WaitingTime = Convert.ToInt32(dt2.Compute("max([WaitingTime])", string.Empty));
            int AssignedPriority = Convert.ToInt32(dt2.Compute("max([AssignedPriority])", string.Empty));
            int CUSOVTNextCCStopInMinute = Convert.ToInt32(dt2.Compute("max([CUSOVTNextCCStopInMinute])", string.Empty));
            double CUSOVTChemicalLifetime = Convert.ToInt32(dt2.Compute("max([CUSOVTChemicalLifetime])", string.Empty));
            //int CUSOVTCCDuration = Convert.ToInt32(dt2.Compute("max([CUSOVTCCDuration])", string.Empty));
            int IgnoreBatchSize = Convert.ToInt32(dt2.Compute("max([IgnoreBatchSize])", string.Empty));
            int InQTime = Convert.ToInt32(dt2.Compute("max([InQTime])", string.Empty));
            int RQT1 = Convert.ToInt32(dt2.Compute("min([RQT1])", string.Empty));
            int RQT2 = Convert.ToInt32(dt2.Compute("min([RQT2])", string.Empty));
            int RQT3 = Convert.ToInt32(dt2.Compute("min([RQT3])", string.Empty));
            dt_input_foup.Rows.Add(dt2.Rows[0]["FOUPID"], NumWafer, dt2.Rows[0]["Seq"], dt2.Rows[0]["Entity"], dt2.Rows[0]["EqpID"], dt2.Rows[0]["EqpType"]
                , IsActive, AvailDispInMinute, AvailTimeInMinute, AdvInhibitInMinute, Priority, WaitingTime, AssignedPriority
                , dt2.Rows[0]["Recipe"], dt2.Rows[0]["PPID"], dt2.Rows[0]["PPIDNumber"], dt2.Rows[0]["ChamberRequired"]
                , dt2.Rows[0]["StopDispatchTime"], dt2.Rows[0]["ProcessTime"], dt2.Rows[0]["RTDEqpType"]
                , dt2.Rows[0]["CUSOVTNextCCStopTime"], CUSOVTNextCCStopInMinute, CUSOVTChemicalLifetime, dt2.Rows[0]["InQTime"]
                , dt2.Rows[0]["RQTEqpType1"], dt2.Rows[0]["RQTSeq1"], RQT1
                , dt2.Rows[0]["RQTEqpType2"], dt2.Rows[0]["RQTSeq2"], RQT2
                , dt2.Rows[0]["RQTEqpType3"], dt2.Rows[0]["RQTSeq3"], RQT3
                , dt2.Rows[0]["QTimeEqpType1"], dt2.Rows[0]["QTimeSeq1"], dt2.Rows[0]["QTime1"]
                , dt2.Rows[0]["QTimeEqpType2"], dt2.Rows[0]["QTimeSeq2"], dt2.Rows[0]["QTime2"]
                , dt2.Rows[0]["QTimeEqpType3"], dt2.Rows[0]["QTimeSeq3"], dt2.Rows[0]["QTime3"]
                , dt2.Rows[0]["EqRecoveryStartTime"], dt2.Rows[0]["EqRecoveryStartTimeInMinute"], dt2.Rows[0]["EqRecoveryEndTime"], dt2.Rows[0]["EqRecoveryEndTimeInMinute"]
                , dt2.Rows[0]["BatchSize"], dt2.Rows[0]["MaxBatchSize"], dt2.Rows[0]["MinWaferCountPerBatch"], dt2.Rows[0]["MinBatchWafers"], dt2.Rows[0]["MaxBatchWafers"]
                , IgnoreBatchSize);
        }
    }
}
