    dt_input_foup.Columns.Add("CUSOVTNextCCStopTime", typeof(DateTime));
    dt_input_foup.Columns.Add("CUSOVTNextCCStopInMinute", typeof(double));
    dt_input_foup.Columns.Add("CUSOVTChemicalLifetime", typeof(double));
    //dt_input_foup.Columns.Add("CUSOVTCCDuration", typeof(double));
